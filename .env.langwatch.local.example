# Pantheon-Pi local LangWatch development template.
# Copy to .env.langwatch.local and fill in the local self-hosted API key.
# The copied file is gitignored; do not commit real keys.

LANGWATCH_ENDPOINT=http://localhost:5560
LANGWATCH_API_KEY=replace-with-local-langwatch-api-key
# Optional: print sanitized LangWatch initialization/flush diagnostics.
# PANTHEON_LANGWATCH_DEBUG=true

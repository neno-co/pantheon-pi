{
	"schemaVersion": 1,
	"source": "pi-native pantheon-pi packaged baseline; packaged agents use package-relative agents/bin scripts",
	"defaults": {
		"defaultAgent": "athena",
		"defaultPermissions": "approve-all",
		"runType": "session",
		"ttlSeconds": 86400,
		"maxTurnsPolicy": "Omit maxTurns for implementation/grading agents (vulkanus, dike, argus, prometheus); rely on timeoutSeconds. Low caps (<30) allowed only for scoped read-only lookups. No upper bound in the schema (removed). Prefer runType=session with a named sessionId (<bead-id>-<agent>-<purpose>) for all substantive work; reserve runType=exec for one-shot stateless lookups only."
	},
	"agents": {
		"argus": {
			"command": "npx",
			"args": ["-y", "@agentclientprotocol/claude-agent-acp@latest"],
			"kind": "claude-agent-acp",
			"prompt": "agents/prompts/argus.md",
			"model": "claude-opus-4-8",
			"notes": "Pantheon-owned Claude Code route: claude-opus-4-8 with agents/prompts/argus.md injected via acpx --append-system-prompt.",
			"defaultPermissions": "approve-all"
		},
		"athena": {
			"command": "env",
			"args": ["PI_ACP_PI_COMMAND=./agents/bin/athena", "npx", "-y", "pi-acp@latest"],
			"kind": "pi-acp-packaged-prompt-agent",
			"prompt": "agents/prompts/athena.md",
			"model": "openai-codex/gpt-5.5"
		},
		"codebase-analyzer": {
